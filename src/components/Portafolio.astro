---
import { proyectos } from '../data/proyectos';
import { useTranslations, tr, type Lang } from '../i18n/utils';
import { defaultLang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

// Con un solo proyecto usamos un layout "destacado" (spotlight) en vez del
// carrusel, que se vería vacío. Con 2+ proyectos volvemos al carrusel.
const unico = proyectos.length === 1 ? proyectos[0] : null;
---

<div class="seccion-portafolio" id="portafolio">
  <div class="portafolio-header">
    <span class="eyebrow-text">{t.portafolio.eyebrow}</span>
    <h2 class="titulo-destacado">{t.portafolio.titulo}</h2>
    <p class="portafolio-intro">{t.portafolio.intro}</p>
  </div>

  {unico ? (
    <div class={`proyecto-destacado ${unico.clase}`}>
      <div
        class="destacado-visual"
        style={unico.screenshot ? `background-image: url('${unico.screenshot}')` : undefined}
      >
        {unico.galeria && (
          <div class="destacado-galeria">
            {unico.galeria.map((src, gi) => (
              <img class="destacado-shot" src={src} alt={`${unico.titulo} captura ${gi + 1}`} loading="lazy" />
            ))}
          </div>
        )}
      </div>
      <div class="destacado-info">
        <span class="categoria-tag">{tr(unico.tag, lang)}</span>
        <h3 class="destacado-titulo">{unico.titulo}</h3>
        <p class="destacado-desc">{tr(unico.descripcion, lang)}</p>
        {unico.detalles?.destacados && (
          <ul class="destacado-lista">
            {unico.detalles.destacados.slice(0, 3).map((d) => (
              <li>
                <i class="fas fa-check" />
                <span>{tr(d, lang)}</span>
              </li>
            ))}
          </ul>
        )}
        <div class="tecnologias-iconos destacado-iconos">
          {unico.iconos.map((ic) => (
            <i class={ic.icon} title={ic.title} />
          ))}
        </div>
        <div class="proyecto-enlaces destacado-enlaces">
          {unico.codigo && (
            <a class="enlace-proyecto" href={unico.codigo} target="_blank" rel="noopener noreferrer">
              <i class="fab fa-github" />
              <span>{t.portafolio.codigo}</span>
            </a>
          )}
          {unico.demo && (
            <a class="enlace-proyecto enlace-demo" href={unico.demo} target="_blank" rel="noopener noreferrer">
              <i class="fas fa-external-link-alt" />
              <span>{t.portafolio.demo}</span>
            </a>
          )}
          {unico.detalles && (
            <button class="enlace-proyecto detalle-btn" data-modal-target="modal-0" title={t.portafolio.masInfo}>
              <i class="fas fa-info-circle" />
              <span>{t.portafolio.detalles}</span>
            </button>
          )}
        </div>
      </div>
    </div>
  ) : (
  <div class="carrusel">
    <button class="carrusel-btn carrusel-btn-atras" aria-label="Anterior">
      <i class="fas fa-chevron-left"></i>
    </button>
    <div class="carrusel-contenido" id="carruselId">
      {
        proyectos.map((p, i) => (
          <div class={`elemento-carrusel ${p.clase} ${p.screenshot ? 'tiene-imagen' : ''}`}>
            <div class="caja-brillo"></div>
            {p.screenshot && (
              <div
                class={`proyecto-screenshot ${p.galeria ? 'tiene-galeria' : ''}`}
                style={`background-image: url('${p.screenshot}')`}
              >
                {p.galeria && (
                  <div class="proyecto-galeria">
                    {p.galeria.map((src, gi) => (
                      <img class="galeria-shot" src={src} alt={`${p.titulo} captura ${gi + 1}`} loading="lazy" />
                    ))}
                  </div>
                )}
              </div>
            )}
            <div class="caracteristicas-proyecto">
              <div class="info-proyecto">
                <span class="categoria-tag">{tr(p.tag, lang)}</span>
                <h4>{p.titulo}</h4>
                <p>{tr(p.descripcion, lang)}</p>
              </div>
              <div class="tecnologias-usadas">
                <div class="tecnologias-iconos">
                  {p.iconos.map((ic) => (
                    <i class={ic.icon} title={ic.title} />
                  ))}
                </div>
              </div>
              <div class="proyecto-enlaces">
                {p.codigo && (
                  <a
                    class="enlace-proyecto"
                    href={p.codigo}
                    target="_blank"
                    rel="noopener noreferrer"
                    title={t.portafolio.verRepo}
                  >
                    <i class="fab fa-github" />
                    <span>{t.portafolio.codigo}</span>
                  </a>
                )}
                {p.demo && (
                  <a
                    class="enlace-proyecto enlace-demo"
                    href={p.demo}
                    target="_blank"
                    rel="noopener noreferrer"
                    title={t.portafolio.verDemo}
                  >
                    <i class="fas fa-external-link-alt" />
                    <span>{t.portafolio.demo}</span>
                  </a>
                )}
                {p.detalles && (
                  <button class="enlace-proyecto detalle-btn" data-modal-target={`modal-${i}`} title={t.portafolio.masInfo}>
                    <i class="fas fa-info-circle" />
                    <span>{t.portafolio.detalles}</span>
                  </button>
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>
    <button class="carrusel-btn carrusel-btn-adelante" aria-label="Siguiente">
      <i class="fas fa-chevron-right"></i>
    </button>
  </div>
  )}

  <div class="mas-proyectos">
    <div class="mas-proyectos-card">
      <span>{t.portafolio.masProyectos}</span>
      <a href="https://github.com/Vktornaj" target="_blank" rel="noopener noreferrer">
        <i class="fab fa-github"></i>
        <span>{t.portafolio.verGithub}</span>
      </a>
    </div>
  </div>
</div>

{
  proyectos.map((p, i) =>
    p.detalles ? (
      <div class="proyecto-modal" id={`modal-${i}`} role="dialog" aria-modal="true" aria-hidden="true">
        <div class="modal-overlay" data-modal-cerrar></div>
        <div class={`modal-caja ${p.galeria ? 'con-galeria' : ''}`}>
          <button class="modal-cerrar" aria-label={t.portafolio.cerrar} data-modal-cerrar>
            <i class="fas fa-times"></i>
          </button>
          <div class="modal-grid">
            <div class="modal-info">
              <span class="categoria-tag modal-tag">{tr(p.tag, lang)}</span>
              <h3 class="modal-titulo">{p.titulo}</h3>
              <p class="modal-resumen">{tr(p.detalles.resumen, lang)}</p>

              {p.detalles.arquitectura && (
                <div class="modal-seccion">
                  <h4>{t.portafolio.arquitectura}</h4>
                  <p>{tr(p.detalles.arquitectura, lang)}</p>
                </div>
              )}

              {p.detalles.destacados && (
                <div class="modal-seccion">
                  <h4>{t.portafolio.destacados}</h4>
                  <ul class="modal-lista">
                    {p.detalles.destacados.map((d) => (
                      <li>{tr(d, lang)}</li>
                    ))}
                  </ul>
                </div>
              )}

              {p.detalles.stack && (
                <div class="modal-stack">
                  {p.detalles.stack.map((s) => (
                    <span class="stack-chip">{s}</span>
                  ))}
                </div>
              )}

              <div class="proyecto-enlaces modal-enlaces">
                {p.codigo && (
                  <a class="enlace-proyecto" href={p.codigo} target="_blank" rel="noopener noreferrer">
                    <i class="fab fa-github" />
                    <span>{t.portafolio.codigo}</span>
                  </a>
                )}
                {p.demo && (
                  <a class="enlace-proyecto enlace-demo" href={p.demo} target="_blank" rel="noopener noreferrer">
                    <i class="fas fa-external-link-alt" />
                    <span>{t.portafolio.demo}</span>
                  </a>
                )}
              </div>
            </div>

            {p.galeria && (
              <div class="modal-galeria">
                {p.galeria.map((src, gi) => (
                  <a
                    class="modal-galeria-item"
                    href={src}
                    target="_blank"
                    rel="noopener noreferrer"
                    title={t.portafolio.verTamano}
                  >
                    <img src={src} alt={`${p.titulo} captura ${gi + 1}`} loading="lazy" />
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    ) : null
  )
}

<style>
  .seccion-portafolio {
    grid-area: portafolio;
    width: 100%;
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .portafolio-header {
    text-align: center;
    max-width: 48rem;
    margin: 0 auto 3rem auto;
  }

  .eyebrow-text {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-azul-claro);
    letter-spacing: 0.15em;
    display: block;
    margin-bottom: 0.5rem;
  }

  .titulo-destacado {
    font-size: 3rem;
    font-weight: 900;
    letter-spacing: -0.04em;
    background: linear-gradient(135deg, var(--color-texto-primario) 30%, var(--color-azul-claro));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-top: 0;
    margin-bottom: 1.5rem;
    display: inline-block;
  }

  .portafolio-intro {
    font-size: 1.1rem;
    line-height: 1.75;
    opacity: 0.8;
    color: var(--color-texto-primario);
    max-width: 50ch;
    margin: 0 auto;
  }

  /* Carrusel */
  .carrusel {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    margin-top: 2rem;
  }

  .carrusel-btn {
    border: 1px solid var(--glass-border);
    outline: none;
    border-radius: 50%;
    height: 48px;
    width: 48px;
    background: var(--glass-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: var(--color-texto-primario);
    cursor: pointer;
    font-size: 1rem;
    transition: var(--transition-smooth);
    box-shadow: var(--glass-shadow);
    z-index: 10;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .carrusel-btn:hover {
    background: var(--color-azul-claro);
    color: white;
    border-color: var(--color-azul-claro);
    transform: scale(1.1);
    box-shadow: 0 8px 20px rgba(99, 102, 241, 0.4);
  }

  .carrusel-btn-atras {
    position: absolute;
    left: -24px;
  }

  .carrusel-btn-adelante {
    position: absolute;
    right: -24px;
  }

  .carrusel-contenido {
    height: 480px;
    display: flex;
    overflow-x: auto;
    scroll-behavior: smooth;
    width: 100%;
    padding: 15px 0;
    box-sizing: border-box;
    scrollbar-width: none; /* Firefox */
  }

  .carrusel-contenido::-webkit-scrollbar {
    display: none; /* Chrome, Safari, Opera */
  }

  .elemento-carrusel {
    height: 440px;
    min-width: 290px;
    width: 290px;
    margin-right: 30px;
    border-radius: var(--radius-md);
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
    position: relative;
    overflow: hidden;
    transition: var(--transition-smooth);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  /* Tarjetas con screenshot: banda de imagen arriba + contenido abajo */
  .tiene-imagen {
    justify-content: flex-start;
  }

  .proyecto-screenshot {
    flex: 0 0 165px;
    width: 100%;
    background-size: cover;
    background-position: center top;
    position: relative;
    z-index: 1;
  }

  /* Difumina el borde inferior de la imagen hacia el panel de contenido */
  .proyecto-screenshot::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 70%, rgba(0, 0, 0, 0.35));
  }

  /* Banda con abanico de capturas de la app */
  .proyecto-screenshot.tiene-galeria {
    flex-basis: 200px;
    background-color: #05070d;
  }

  .proyecto-screenshot.tiene-galeria::after {
    background: linear-gradient(
      to bottom,
      rgba(5, 7, 13, 0.55),
      rgba(5, 7, 13, 0.3) 50%,
      rgba(0, 0, 0, 0.55)
    );
  }

  .proyecto-galeria {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }

  .galeria-shot {
    height: 86%;
    width: auto;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.22);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.5);
    object-fit: cover;
    transition: var(--transition-smooth);
  }

  .galeria-shot:nth-child(1) {
    transform: rotate(-10deg) translateX(34px) translateY(6px);
  }

  .galeria-shot:nth-child(2) {
    transform: translateY(-6px);
    z-index: 3;
  }

  .galeria-shot:nth-child(3) {
    transform: rotate(10deg) translateX(-34px) translateY(6px);
  }

  /* Al pasar el cursor, el abanico se abre un poco */
  .elemento-carrusel:hover .galeria-shot:nth-child(1) {
    transform: rotate(-13deg) translateX(18px) translateY(0);
  }

  .elemento-carrusel:hover .galeria-shot:nth-child(3) {
    transform: rotate(13deg) translateX(-18px) translateY(0);
  }

  .tiene-imagen .caracteristicas-proyecto {
    flex: 1 1 auto;
    height: auto;
    background: var(--card-overlay);
    backdrop-filter: blur(2px);
  }

  /* Caja de brillo interactiva */
  .caja-brillo {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, transparent 50%, transparent 100%);
    opacity: 0.5;
    z-index: 1;
    pointer-events: none;
    transition: var(--transition-smooth);
  }

  .elemento-carrusel:hover {
    transform: translateY(-8px) scale(1.01);
    border-color: rgba(99, 102, 241, 0.4);
  }

  .elemento-carrusel:hover .caja-brillo {
    opacity: 0.9;
    background: linear-gradient(135deg, rgba(255,255,255,0.12) 0%, rgba(255,255,255,0.02) 60%, transparent 100%);
  }

  /* Gradientes de color premium */
  .proyecto-1 { 
    background: var(--card-bg-1); 
  }
  .proyecto-1:hover {
    box-shadow: 0 15px 35px rgba(162, 28, 175, 0.2), var(--glass-shadow);
  }

  .proyecto-2 { 
    background: var(--card-bg-2); 
  }
  .proyecto-2:hover {
    box-shadow: 0 15px 35px rgba(59, 130, 246, 0.25), var(--glass-shadow);
  }

  .proyecto-3 { 
    background: var(--card-bg-3); 
  }
  .proyecto-3:hover {
    box-shadow: 0 15px 35px rgba(249, 115, 22, 0.2), var(--glass-shadow);
  }

  .proyecto-4 { 
    background: var(--card-bg-4); 
  }
  .proyecto-4:hover {
    box-shadow: 0 15px 35px rgba(6, 182, 212, 0.2), var(--glass-shadow);
  }

  .proyecto-5 { 
    background: var(--card-bg-5); 
  }
  .proyecto-5:hover {
    box-shadow: 0 15px 35px rgba(16, 185, 129, 0.2), var(--glass-shadow);
  }

  .caracteristicas-proyecto {
    padding: 1.5rem;
    background: var(--card-overlay);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    width: 100%;
    height: 100%;
    box-sizing: border-box;
    z-index: 2;
  }

  .info-proyecto {
    width: 100%;
  }

  .categoria-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-contraste-fuerte);
    display: block;
    margin-bottom: 0.5rem;
  }

  .caracteristicas-proyecto h4 {
    font-size: 1.3rem;
    font-weight: 800;
    margin: 0 0 0.5rem 0;
    color: var(--card-text-title);
    letter-spacing: -0.02em;
  }

  .caracteristicas-proyecto p {
    font-size: 0.85rem;
    color: var(--card-text-desc);
    margin: 0 0 1.2rem 0;
    line-height: 1.5;
    opacity: 0.95;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tecnologias-usadas {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 0.9rem;
  }

  /* Enlaces a código y demo */
  .proyecto-enlaces {
    display: flex;
    gap: 0.6rem;
    margin-top: 0.9rem;
  }

  .enlace-proyecto {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--card-text-title);
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.14);
    padding: 0.4rem 0.85rem;
    border-radius: var(--radius-sm);
    transition: var(--transition-smooth);
  }

  .enlace-proyecto:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
  }

  .enlace-demo {
    background: var(--color-azul-claro);
    border-color: var(--color-azul-claro);
    color: #fff;
  }

  .enlace-demo:hover {
    box-shadow: 0 6px 18px rgba(99, 102, 241, 0.4);
  }

  .detalle-btn {
    cursor: pointer;
    font-family: inherit;
  }

  /* ===== Modal de detalles ===== */
  .proyecto-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  .proyecto-modal.abierto {
    display: flex;
  }

  .modal-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    animation: modalFade 0.25s ease both;
  }

  .modal-caja {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 560px;
    max-height: 85vh;
    overflow-y: auto;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-md);
    box-shadow: var(--glass-shadow);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding: 2rem;
    animation: modalPop 0.28s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .modal-caja.con-galeria {
    max-width: 940px;
  }

  .modal-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .con-galeria .modal-grid {
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.25fr);
    gap: 2.2rem;
    align-items: start;
  }

  /* Galería de capturas dentro del modal */
  .modal-galeria {
    display: flex;
    gap: 0.7rem;
  }

  .modal-galeria-item {
    flex: 1;
    display: block;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--glass-border);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.4);
    transition: var(--transition-smooth);
  }

  .modal-galeria-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 32px rgba(0, 0, 0, 0.55);
    border-color: rgba(99, 102, 241, 0.5);
  }

  .modal-galeria-item img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (max-width: 760px) {
    .con-galeria .modal-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  .modal-cerrar {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    color: var(--color-texto-primario);
    cursor: pointer;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-smooth);
  }

  .modal-cerrar:hover {
    background: var(--color-azul-claro);
    color: #fff;
    border-color: var(--color-azul-claro);
  }

  .modal-tag {
    color: var(--color-azul-claro);
  }

  .modal-titulo {
    font-size: 1.7rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0.3rem 0 1rem 0;
    color: var(--color-texto-primario);
  }

  .modal-resumen {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-texto-primario);
    opacity: 0.85;
    margin: 0;
  }

  .modal-seccion {
    margin-top: 1.5rem;
  }

  .modal-seccion h4 {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-azul-claro);
    margin: 0 0 0.6rem 0;
  }

  .modal-seccion p {
    font-size: 0.92rem;
    line-height: 1.7;
    color: var(--color-texto-primario);
    opacity: 0.85;
    margin: 0;
  }

  .modal-lista {
    margin: 0;
    padding-left: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .modal-lista li {
