---
import { proyectos } from '../data/proyectos';
import { obtenerRepos } from '../lib/github';

// Datos de GitHub (build time). Si no hay token o falla, los valores son null
// y cada tarjeta cae al contenido manual.
const datosGithub = await obtenerRepos(proyectos.map((p) => p.repo));

function formatoFecha(iso: string | null): string | null {
  if (!iso) return null;
  return new Date(iso).toLocaleDateString('es-MX', { month: 'short', year: 'numeric' });
}

// Mezcla: lo manual gana; GitHub rellena lo que falte y aporta stars/fecha/url.
const tarjetas = proyectos.map((p) => {
  const gh = datosGithub.get(p.repo) ?? null;
  return {
    ...p,
    titulo: p.titulo || gh?.nombre || 'Proyecto',
    descripcion: p.descripcion || gh?.descripcion || 'Proyecto disponible en GitHub.',
    url: gh?.url || `https://github.com/${p.repo}`,
    stars: gh?.stars ?? null,
    actualizado: formatoFecha(gh?.actualizado ?? null),
  };
});
---

<div class="seccion-portafolio" id="portafolio">
  <div class="portafolio-header">
    <span class="eyebrow-text">MIS TRABAJOS RECIENTES</span>
    <h2 class="titulo-destacado">Portafolio</h2>
    <p class="portafolio-intro">
      Una cuidada selección de proyectos donde aplico desarrollo backend, machine learning y
      sistemas concurrentes escalables.
    </p>
  </div>

  <div class="carrusel">
    <button class="carrusel-btn carrusel-btn-atras" aria-label="Anterior">
      <i class="fas fa-chevron-left"></i>
    </button>
    <div class="carrusel-contenido" id="carruselId">
      {
        tarjetas.map((p) => (
          <div class={`elemento-carrusel ${p.clase} ${p.screenshot ? 'tiene-imagen' : ''}`}>
            <div class="caja-brillo"></div>
            {p.screenshot && (
              <div class="proyecto-screenshot" style={`background-image: url('${p.screenshot}')`} />
            )}
            <div class="caracteristicas-proyecto">
              <div class="info-proyecto">
                <span class="categoria-tag">{p.tag}</span>
                <h4>{p.titulo}</h4>
                <p>{p.descripcion}</p>
              </div>
              <div class="tecnologias-usadas">
                <div class="tecnologias-iconos">
                  {p.iconos.map((ic) => (
                    <i class={ic.icon} title={ic.title} />
                  ))}
                </div>
                <div class="proyecto-stats">
                  {p.stars !== null && (
                    <span class="stat" title="Stars en GitHub">
                      <i class="fas fa-star" />
                      {p.stars}
                    </span>
                  )}
                  {p.actualizado && (
                    <span class="stat" title="Última actualización">
                      <i class="fas fa-history" />
                      {p.actualizado}
                    </span>
                  )}
                </div>
              </div>
              <div class="proyecto-enlaces">
                <a
                  class="enlace-proyecto"
                  href={p.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  title="Ver repositorio"
                >
                  <i class="fab fa-github" />
                  <span>Código</span>
                </a>
                {p.demo && (
                  <a
                    class="enlace-proyecto enlace-demo"
                    href={p.demo}
                    target="_blank"
                    rel="noopener noreferrer"
                    title="Ver demo en vivo"
                  >
                    <i class="fas fa-external-link-alt" />
                    <span>Demo</span>
                  </a>
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>
    <button class="carrusel-btn carrusel-btn-adelante" aria-label="Siguiente">
      <i class="fas fa-chevron-right"></i>
    </button>
  </div>

  <div class="mas-proyectos">
    <div class="mas-proyectos-card">
      <span>¿Quieres explorar más proyectos?</span>
      <a href="https://github.com/Vktornaj" target="_blank" rel="noopener noreferrer">
        <i class="fab fa-github"></i>
        <span>Ver más en GitHub</span>
      </a>
    </div>
  </div>
</div>

<style>
  .seccion-portafolio {
    grid-area: portafolio;
    width: 100%;
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .portafolio-header {
    text-align: center;
    max-width: 48rem;
    margin: 0 auto 3rem auto;
  }

  .eyebrow-text {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-azul-claro);
    letter-spacing: 0.15em;
    display: block;
    margin-bottom: 0.5rem;
  }

  .titulo-destacado {
    font-size: 3rem;
    font-weight: 900;
    letter-spacing: -0.04em;
    background: linear-gradient(135deg, var(--color-texto-primario) 30%, var(--color-azul-claro));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-top: 0;
    margin-bottom: 1.5rem;
    display: inline-block;
  }

  .portafolio-intro {
    font-size: 1.1rem;
    line-height: 1.75;
    opacity: 0.8;
    color: var(--color-texto-primario);
    max-width: 50ch;
    margin: 0 auto;
  }

  /* Carrusel */
  .carrusel {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    margin-top: 2rem;
  }

  .carrusel-btn {
    border: 1px solid var(--glass-border);
    outline: none;
    border-radius: 50%;
    height: 48px;
    width: 48px;
    background: var(--glass-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: var(--color-texto-primario);
    cursor: pointer;
    font-size: 1rem;
    transition: var(--transition-smooth);
    box-shadow: var(--glass-shadow);
    z-index: 10;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .carrusel-btn:hover {
    background: var(--color-azul-claro);
    color: white;
    border-color: var(--color-azul-claro);
    transform: scale(1.1);
    box-shadow: 0 8px 20px rgba(99, 102, 241, 0.4);
  }

  .carrusel-btn-atras {
    position: absolute;
    left: -24px;
  }

  .carrusel-btn-adelante {
    position: absolute;
    right: -24px;
  }

  .carrusel-contenido {
    height: 450px;
    display: flex;
    overflow-x: auto;
    scroll-behavior: smooth;
    width: 100%;
    padding: 15px 0;
    box-sizing: border-box;
    scrollbar-width: none; /* Firefox */
  }

  .carrusel-contenido::-webkit-scrollbar {
    display: none; /* Chrome, Safari, Opera */
  }

  .elemento-carrusel {
    height: 410px;
    min-width: 290px;
    width: 290px;
    margin-right: 30px;
    border-radius: var(--radius-md);
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
    position: relative;
    overflow: hidden;
    transition: var(--transition-smooth);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  /* Tarjetas con screenshot: banda de imagen arriba + contenido abajo */
  .tiene-imagen {
    justify-content: flex-start;
  }

  .proyecto-screenshot {
    flex: 0 0 165px;
    width: 100%;
    background-size: cover;
    background-position: center top;
    position: relative;
    z-index: 1;
  }

  /* Difumina el borde inferior de la imagen hacia el panel de contenido */
  .proyecto-screenshot::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 70%, rgba(0, 0, 0, 0.35));
  }

  .tiene-imagen .caracteristicas-proyecto {
    flex: 1 1 auto;
    height: auto;
    background: var(--card-overlay);
    backdrop-filter: blur(2px);
  }

  /* Caja de brillo interactiva */
  .caja-brillo {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, transparent 50%, transparent 100%);
    opacity: 0.5;
    z-index: 1;
    pointer-events: none;
    transition: var(--transition-smooth);
  }

  .elemento-carrusel:hover {
    transform: translateY(-8px) scale(1.01);
    border-color: rgba(99, 102, 241, 0.4);
  }

  .elemento-carrusel:hover .caja-brillo {
    opacity: 0.9;
    background: linear-gradient(135deg, rgba(255,255,255,0.12) 0%, rgba(255,255,255,0.02) 60%, transparent 100%);
  }

  /* Gradientes de color premium */
  .proyecto-1 { 
    background: var(--card-bg-1); 
  }
  .proyecto-1:hover {
    box-shadow: 0 15px 35px rgba(162, 28, 175, 0.2), var(--glass-shadow);
  }

  .proyecto-2 { 
    background: var(--card-bg-2); 
  }
  .proyecto-2:hover {
    box-shadow: 0 15px 35px rgba(59, 130, 246, 0.25), var(--glass-shadow);
  }

  .proyecto-3 { 
    background: var(--card-bg-3); 
  }
  .proyecto-3:hover {
    box-shadow: 0 15px 35px rgba(249, 115, 22, 0.2), var(--glass-shadow);
  }

  .proyecto-4 { 
    background: var(--card-bg-4); 
  }
  .proyecto-4:hover {
    box-shadow: 0 15px 35px rgba(6, 182, 212, 0.2), var(--glass-shadow);
  }

  .proyecto-5 { 
    background: var(--card-bg-5); 
  }
  .proyecto-5:hover {
    box-shadow: 0 15px 35px rgba(16, 185, 129, 0.2), var(--glass-shadow);
  }

  .caracteristicas-proyecto {
    padding: 1.5rem;
    background: var(--card-overlay);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    width: 100%;
    height: 100%;
    box-sizing: border-box;
    z-index: 2;
  }

  .info-proyecto {
    width: 100%;
  }

  .categoria-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-contraste-fuerte);
    display: block;
    margin-bottom: 0.5rem;
  }

  .caracteristicas-proyecto h4 {
    font-size: 1.3rem;
    font-weight: 800;
    margin: 0 0 0.5rem 0;
    color: var(--card-text-title);
    letter-spacing: -0.02em;
  }

  .caracteristicas-proyecto p {
    font-size: 0.85rem;
    color: var(--card-text-desc);
    margin: 0 0 1.2rem 0;
    line-height: 1.5;
    opacity: 0.95;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tecnologias-usadas {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 0.9rem;
  }

  /* Estadísticas de GitHub (stars, última actualización) */
  .proyecto-stats {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--card-text-desc);
  }

  .proyecto-stats .stat {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    white-space: nowrap;
    opacity: 0.9;
  }

  .proyecto-stats .fa-star {
    color: #f5c518;
  }

  /* Enlaces a código y demo */
  .proyecto-enlaces {
    display: flex;
    gap: 0.6rem;
    margin-top: 0.9rem;
  }

  .enlace-proyecto {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--card-text-title);
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.14);
    padding: 0.4rem 0.85rem;
    border-radius: var(--radius-sm);
    transition: var(--transition-smooth);
  }

  .enlace-proyecto:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
  }

  .enlace-demo {
    background: var(--color-azul-claro);
    border-color: var(--color-azul-claro);
    color: #fff;
  }

  .enlace-demo:hover {
    box-shadow: 0 6px 18px rgba(99, 102, 241, 0.4);
  }

  /* Iconos de tecnologías en las tarjetas */
  .tecnologias-iconos {
    display: flex;
    gap: 0.8rem;
    font-size: 1.35rem;
  }

  .tecnologias-iconos i {
    transition: var(--transition-smooth);
    opacity: 0.85;
  }

  .tecnologias-iconos i:hover {
    transform: scale(1.15) translateY(-2px);
    opacity: 1;
  }

  .tecnologias-iconos .fa-html5 { color: #e34f26; }
  .tecnologias-iconos .fa-css3-alt { color: #1572b6; }
  .tecnologias-iconos .fa-js-square { color: #f7df1e; }
  .tecnologias-iconos .fa-python { color: #3776ab; }
  .tecnologias-iconos .fa-brain { color: var(--color-contraste-fuerte); }
  .tecnologias-iconos .fa-rust { color: #ff5722; }
  .tecnologias-iconos .fa-java { color: #e76f51; }
  .tecnologias-iconos .fa-database { color: #336791; }
  .tecnologias-iconos .fa-server { color: #a855f7; }
  .tecnologias-iconos .fa-shield-alt { color: #10b981; }
  .tecnologias-iconos .fa-project-diagram { color: #06b6d4; }
  .tecnologias-iconos .fa-chart-line { color: #f43f5e; }
  .tecnologias-iconos .fa-mobile-alt { color: #02569b; }
  .tecnologias-iconos .fa-robot { color: #8b5cf6; }
  .tecnologias-iconos .fa-language { color: #06b6d4; }

  /* Ver más proyectos */
  .mas-proyectos {
    display: flex;
    justify-content: center;
    width: 100%;
    margin-top: 3.5rem;
  }

  .mas-proyectos-card {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-md);
    padding: 1.5rem 2.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    max-width: 600px;
    width: 100%;
    box-shadow: var(--glass-shadow);
  }

  .mas-proyectos-card span {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-texto-primario);
    opacity: 0.9;
  }

  .mas-proyectos-card a {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: white;
    background: linear-gradient(135deg, var(--color-azul-claro2), rgba(99, 102, 241, 0.2));
    border: 1px solid var(--glass-border);
    padding: 0.75rem 1.6rem;
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: 0.9rem;
    transition: var(--transition-smooth);
  }

  .mas-proyectos-card a:hover {
    background: var(--color-azul-claro);
    border-color: var(--color-azul-claro);
    color: white;
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(99, 102, 241, 0.35);
  }

  .mas-proyectos-card a i {
    font-size: 1.2rem;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .titulo-destacado {
      font-size: 2.2rem;
    }
    .portafolio-intro {
      font-size: 1rem;
    }
    .carrusel-contenido {
      padding-left: 0.5rem;
    }
    .carrusel-btn {
      display: none;
    }
    .mas-proyectos-card {
      flex-direction: column;
      text-align: center;
      padding: 1.5rem;
      gap: 1.2rem;
    }
    .mas-proyectos-card a {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script>
  // Carrusel del portafolio
  const carruselContainer = document.querySelector('.carrusel') as HTMLElement;
  const carrusel = document.getElementById('carruselId') as HTMLElement;
  const btnAtras = document.querySelector('.carrusel-btn-atras');
  const btnAdelante = document.querySelector('.carrusel-btn-adelante');
  
  // Ancho base del elemento (290px) + margen (30px)
  const stepSize = 320;

  btnAtras?.addEventListener('click', () => {
    carrusel.scrollBy({ top: 0, left: -stepSize, behavior: 'smooth' });
  });

  btnAdelante?.addEventListener('click', () => {
    carrusel.scrollBy({ top: 0, left: stepSize, behavior: 'smooth' });
  });
</script>
