<script>
  // Carrusel del portafolio
  const carruselContainer = document.querySelector('.carrusel') as HTMLElement;
  const carrusel = document.getElementById('carruselId') as HTMLElement;
  const btnAtras = document.querySelector('.carrusel-btn-atras');
  const btnAdelante = document.querySelector('.carrusel-btn-adelante');
  
  // Ancho base del elemento (290px) + margen (30px)
  const stepSize = 320;

  btnAtras?.addEventListener('click', () => {
    carrusel.scrollBy({ top: 0, left: -stepSize, behavior: 'smooth' });
  });

  btnAdelante?.addEventListener('click', () => {
    carrusel.scrollBy({ top: 0, left: stepSize, behavior: 'smooth' });
  });

  // Modal de detalles
  const abrirModal = (modal: HTMLElement) => {
    modal.classList.add('abierto');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  };

  const cerrarModal = (modal: HTMLElement) => {
    modal.classList.remove('abierto');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  };

  document.querySelectorAll<HTMLElement>('[data-modal-target]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-modal-target');
      const modal = id ? document.getElementById(id) : null;
      if (modal) abrirModal(modal);
    });
  });

  document.querySelectorAll<HTMLElement>('.proyecto-modal').forEach((modal) => {
    modal.querySelectorAll('[data-modal-cerrar]').forEach((el) => {
      el.addEventListener('click', () => cerrarModal(modal));
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document
        .querySelectorAll<HTMLElement>('.proyecto-modal.abierto')
        .forEach((modal) => cerrarModal(modal));
    }
  });
</script>
