---
import RedesSociales from './RedesSociales.astro';
---

<div class="sobre-mi" id="sobre-mi">
  <RedesSociales />
  <h1>
    <span class="small-text dark-text">Soy Desarrollador</span> <br /> Backend y Machine Learning
  </h1>
  <br />
  <span>
    Domino tecnologías del servidor que me permiten abordar todo tipo de proyectos,
    tambien tengo gran pasion por la inteligencia artificial, me gustan los retos y hacer
    proyectos escalables de calidad.
  </span>
  <div class="accesos-rapidos">
    <a href="#portafolio">Portafolio</a>
    <a
      href="https://drive.google.com/file/d/1TrdIb0DWQYv9YbZ_J5-ZHjfyrQ1Wz7Om/view?usp=sharing"
      target="blank">CV</a
    >
  </div>
  <div class="ir-abajo">
    <button class="boton-ir-abajo">
      <i class="fas fa-chevron-down"></i>
      <i class="fas fa-chevron-down"></i>
    </button>
  </div>
</div>

<div class="imagen" id="imagen">
  <div class="fondo-foto-perfil"></div>
  <div class="mascara-foto-perfil">
    <img src="/assets/perfil.png" alt="imagen de perfil" />
  </div>
</div>

<style>
  .sobre-mi {
    display: flex;
    flex-direction: column;
    grid-area: sobremi;
    justify-content: center;
  }

  /* Título principal en Roboto Mono (estética "developer") */
  .sobre-mi h1 {
    font-family: var(--font-mono);
    font-size: 3.4rem;
    line-height: 1.3;
    font-weight: 700;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
    max-width: 18ch;
  }

  /* El eyebrow "Soy Desarrollador" se mantiene en Roboto */
  .sobre-mi h1 span.small-text {
    font-family: var(--font-body);
    font-size: 1.4rem;
    font-weight: 500;
    letter-spacing: 0;
    color: var(--color-azul-claro);
    display: block;
    margin-bottom: 0.75rem;
  }

  .sobre-mi h1 span.dark-text {
    opacity: 0.7;
  }

  .sobre-mi > span {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--color-texto-primario);
    opacity: 0.85;
    max-width: 30rem;
  }

  .accesos-rapidos {
    display: flex;
    gap: 1.2rem;
    margin-top: 2rem;
  }

  .accesos-rapidos > a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    border-radius: var(--radius-sm);
    padding: 0.8rem 1.8rem;
    transition: var(--transition-smooth);
  }

  .accesos-rapidos > a:first-child {
    color: var(--color-texto-primario);
    border: 1px solid var(--color-azul-claro2);
    background: var(--glass-bg);
  }

  .accesos-rapidos > a:first-child:hover {
    background: var(--color-azul-claro2);
    border-color: var(--color-azul-claro);
    transform: translateY(-2px);
  }

  .accesos-rapidos > a:last-child {
    color: white;
    background: var(--color-azul-claro);
    border: 1px solid var(--color-azul-claro);
    box-shadow: 0 4px 14px rgba(99, 102, 241, 0.3);
  }

  .accesos-rapidos > a:last-child:hover {
    background: var(--color-azul-vivo);
    border-color: var(--color-azul-vivo);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(79, 70, 229, 0.4);
  }

  /* Boton ir abajo */
  .ir-abajo {
    margin-top: 4rem;
    display: flex;
    justify-content: center;
  }

  .boton-ir-abajo {
    background: none;
    border: none;
    color: var(--color-texto-primario);
    font-size: 1.4rem;
    cursor: pointer;
    opacity: 0.6;
    transition: var(--transition-smooth);
    animation: bounce 2s infinite;
  }

  .boton-ir-abajo:hover {
    opacity: 1;
    color: var(--color-azul-claro);
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% {
      transform: translateY(0);
    }
    40% {
      transform: translateY(-10px);
    }
    60% {
      transform: translateY(-5px);
    }
  }

  /* Imagen de perfil */
  .imagen {
    grid-area: imagen;
    justify-self: center;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 22rem;
  }

  .fondo-foto-perfil {
    position: absolute;
    background: linear-gradient(135deg, var(--color-azul-claro), var(--color-contraste-fuerte));
    height: 18rem;
    width: 18rem;
    border-radius: 50%;
    filter: blur(30px);
    opacity: 0.35;
    transition: var(--transition-smooth);
  }

  .mascara-foto-perfil {
    position: absolute;
    height: 18rem;
    width: 18rem;
    border-radius: 50%;
    border: 3px solid var(--color-azul-claro2);
    overflow: hidden;
    box-shadow: var(--glass-shadow);
    background: var(--color-azul-fuerte);
    transition: var(--transition-smooth);
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .mascara-foto-perfil:hover {
    border-color: var(--color-azul-claro);
    transform: scale(1.03);
  }

  .mascara-foto-perfil > img {
    height: 100%;
    width: 100%;
    object-fit: cover;
    transition: var(--transition-smooth);
  }

  .mascara-foto-perfil:hover > img {
    transform: scale(1.05);
  }

  @media screen and (max-width: 1024px) {
    .sobre-mi h1 {
      font-size: 2.6rem;
    }
    .sobre-mi h1 span.small-text {
      font-size: 1.25rem;
    }
  }

  @media (max-width: 860px) {
    .imagen {
      min-height: 14rem;
      margin-top: 2rem;
    }
    .fondo-foto-perfil,
    .mascara-foto-perfil {
      height: 12rem;
      width: 12rem;
    }
  }

  @media screen and (max-width: 768px) {
    .sobre-mi {
      text-align: center;
      align-items: center;
    }
    /* .redes lo renderiza <RedesSociales />: override cross-componente */
    .sobre-mi :global(.redes) {
      justify-content: center;
    }
    .accesos-rapidos {
      width: 100%;
      justify-content: center;
    }
    .boton-ir-abajo {
      display: none;
    }
    .imagen {
      min-height: 14rem;
      margin-top: 1rem;
    }
  }
</style>

<script>
  // Scroll suave al pulsar el botón "ir abajo"
  document.querySelector('.boton-ir-abajo')?.addEventListener('click', () => {
    window.scroll({ top: 960, left: 0, behavior: 'smooth' });
  });
</script>
