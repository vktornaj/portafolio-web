---
import RedesSociales from './RedesSociales.astro';
import { useTranslations, type Lang } from '../i18n/utils';
import { defaultLang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<footer class="footer">
  <div class="footer-content">
    <div class="col-copyright">
      <span class="footer-brand">Eduardo García</span>
      <span class="footer-copy">{t.footer.copy}</span>
    </div>

    <div class="col-social">
      <span class="social-label">{t.footer.redes}</span>
      <RedesSociales />
    </div>
  </div>
</footer>

<style>
  .footer {
    grid-area: footer;
    width: 100%;
    border-top: 1px solid var(--glass-border);
    margin-top: 6rem;
    padding: 3rem 0 5rem 0;
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .col-copyright {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .footer-brand {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.1rem;
    letter-spacing: -0.02em;
    color: var(--color-texto-primario);
  }

  .footer-copy {
    font-size: 0.85rem;
    opacity: 0.6;
    color: var(--color-texto-primario);
  }

  .col-social {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  .social-label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-azul-claro);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* Override local de redes sociales en el footer */
  .footer :global(.redes) {
    gap: 0.6rem;
  }

  .footer :global(.icon) {
    height: 2.3rem;
    width: 2.3rem;
    font-size: 0.95rem;
  }

  @media (max-width: 768px) {
    .footer {
      padding-bottom: 7rem; /* Espacio extra para que no tape la barra inferior móvil */
    }
    
    .footer-content {
      flex-direction: column;
      gap: 2rem;
      text-align: center;
    }
    
    .col-copyright {
      align-items: center;
    }
    
    .col-social {
      flex-direction: column;
      gap: 0.8rem;
    }
  }
</style>
